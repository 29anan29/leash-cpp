// 入口模块：导入 math 与 text，使用文件/系统/AI 能力产出报告
import "math.ae"
import "text.ae"
package file
package os
package ai

fn main
  out(section("Leash 多文件协同报告"))
  out("")
  let count = 0
  let total = 0
  let i = 2
  while i <= 100
    if is_prime(i)
      out(describe(i))
      count = count + 1
      total = total + i
    i = i + 1
  out("")
  out(hr())
  let report = "1..100 共 " + count + " 个质数, 累加和=" + total
  out(report)
  append("/tmp/leash_mf.txt", report + "\n")
  let model = env("LEASH_MODEL")
  if model == ""
    model = "gpt-4o-mini"
  out(chat(model, "你是简洁助手", "用一句话总结: " + report))
  out("完成")
