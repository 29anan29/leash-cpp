// config.ae — 代理配置（agent.json）读写
// 能力：file（read/write/exists 为原生函数，入口已声明 package file，全局可用）
package file

fn cfg_default() -> map
  return {"system": "你是一个简洁、有帮助的助手。", "history_file": "agent_history.json", "temperature": 0.7, "max_turns": 8, "model": ""}

fn cfg_load(path: str) -> map requires file
  if exists(path)
    return parse(read(path))
  let d = cfg_default()
  write(path, stringify(d))
  return d

fn cfg_save(path: str, cfg: map) requires file
  write(path, stringify(cfg))
