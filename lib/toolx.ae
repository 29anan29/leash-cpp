// toolx — 工具（对标 LangChain Tool / ToolRegistry）
import "string"
import "list"
package file
package time

fn toolx_new(name: str, description: str) -> map
  return {"name": name, "description": description, "parameters": {}}

fn toolx_param(t: map, name: str, typ: str, desc: str) -> map
  let params = t["parameters"]
  params[name] = {"type": typ, "description": desc}
  t["parameters"] = params
  return t

fn toolx_find(tools: list, name: str)
  let mut i = 0
  while i < len(tools)
    if tools[i]["name"] == name
      return tools[i]
    i = i + 1
  return nil

// 渲染成 ReAct 可用的工具说明
fn toolx_describe(tools: list) -> str
  let mut buf = ""
  let mut i = 0
  while i < len(tools)
    let t = tools[i]
    buf = buf + "- " + t["name"] + ": " + t["description"] + "\n"
    i = i + 1
  return buf

// 执行工具（内置工具 + 自定义区）。返回观察结果字符串。
fn toolx_dispatch(name: str, input: str) -> str requires file time
  if name == "calculator"
    return tool_calc(input)
  else if name == "get_time"
    return tool_time()
  else if name == "read_file"
    return tool_read(input)
  // ===== 用户自定义工具请加在下面 =====
  else if name == "note"
    return "已记录: " + input
  return "未知工具: " + name

fn tool_calc(input: str) -> str
  let sp = str_split(str_trim(input), " ")
  if len(sp) != 3
    return "用法: <数> <运算符 + - * /> <数>"
  let a = parse(sp[0])
  let op = sp[1]
  let b = parse(sp[2])
  if op == "+"
    return stringify(a + b)
  else if op == "-"
    return stringify(a - b)
  else if op == "*"
    return stringify(a * b)
  else if op == "/"
    return stringify(a / b)
  return "不支持的运算符: " + op

fn tool_time() -> str requires time
    return "当前时间戳: " + stringify(now())

fn tool_read(path: str) -> str requires file
  if str_contains(path, "..") or str_contains(path, "~") or (len(path) > 0 and path[0] == "/")
    return "[安全拒绝] 路径穿越: " + path
  if exists(path)
    return read(path)
  return "文件不存在: " + path
