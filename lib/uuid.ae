// UUID v4 生成（依赖 random 包）
// 导入后调用：uuid_v4
package random

fn uuid_v4() -> str
    let hexd = "0123456789abcdef"
    let mut buf = ""
    let mut i = 0
    while i < 36
        if i == 8 or i == 13 or i == 18 or i == 23
            buf = buf + "-"
        else if i == 14
            buf = buf + "4"
        else if i == 19
            buf = buf + hexd[int(0, 3) + 8]
        else
            buf = buf + hexd[int(0, 15)]
        i = i + 1
    return buf
