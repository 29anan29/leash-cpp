// 数值近似工具：clamp / lerp / sign / 四舍五入到指定位数
fn approx_clamp(x: float, lo: float, hi: float) -> float
    if x < lo
        return lo
    if x > hi
        return hi
    return x

fn approx_lerp(a: float, b: float, t: float) -> float
    return a + (b - a) * t

fn approx_sign(x: float) -> int
    if x > 0.0
        return 1
    if x < 0.0
        return -1
    return 0

fn approx_round_to(x: float, digits: int) -> float
    let f = pow(10.0, digits)
    return round(x * f) / f
