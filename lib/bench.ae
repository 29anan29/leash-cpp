// 计时（依赖 time / humanize）
// 用法：let t = bench_start()  ...  bench_end("阶段", t)
package time
import "humanize"

fn bench_start() -> int requires time
    return now()

fn bench_end(label: str, start: int) -> str requires time
    let sec = now() - start
    return label + " 用时 " + hzn_itoa(sec) + "s"
