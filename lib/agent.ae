// 简易 Agent 包（基于 ai 原生包）
// 导入后可直接调用：agent_step / agent_chain

package ai

fn agent_step(question: str) -> str
    return chat("你是一个有帮助的 AI 代理，请用简洁的中文回答。", question)

fn agent_chain(questions: list) -> list
    let res = []
    let mut i = 0
    while i < len(questions)
        res = res + [chat("你是一个有帮助的 AI 代理。", questions[i])]
        i = i + 1
    return res
