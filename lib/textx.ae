// textx — 文本处理：排版 + 文档切分（对标 LangChain TextSplitter）
import "string"
import "list"

fn textx_wrap(s: str, width: int)
  let words = str_split(s, " ")
  let mut lines = []
  let mut line = ""
  let mut i = 0
  while i < len(words)
    let w = words[i]
    if len(line) == 0
      line = w
    else
      if len(line) + 1 + len(w) <= width
        line = line + " " + w
      else
        lines = list_push(lines, line)
        line = w
    i = i + 1
  if len(line) > 0
    lines = list_push(lines, line)
  return str_join(lines, "\n")

fn textx_truncate(s: str, n: int)
  if len(s) <= n
    return s
  if n <= 3
    return s[0 : n]
  return s[0 : n - 3] + "..."

fn textx_center(s: str, width: int)
  let pad = width - len(s)
  if pad <= 0
    return s
  let left = pad / 2
  let right = pad - left
  let mut l = ""
  let mut i = 0
  while i < left
    l = l + " "
    i = i + 1
  let mut r = ""
  let mut j = 0
  while j < right
    r = r + " "
    j = j + 1
  return l + s + r

// 按词数切分长文本为块（用于 RAG 建索引）
fn textx_split(text: str, max_words: int) -> list
  let words = str_split(text, " ")
  let mut chunks = []
  let mut cur = ""
  let mut count = 0
  let mut i = 0
  while i < len(words)
    let w = words[i]
    if count >= max_words and cur != ""
      chunks = list_push(chunks, cur)
      cur = ""
      count = 0
    if cur == ""
      cur = w
    else
      cur = cur + " " + w
    count = count + 1
    i = i + 1
  if cur != ""
    chunks = list_push(chunks, cur)
  return chunks
