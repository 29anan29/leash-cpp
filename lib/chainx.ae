// chainx — 链（对标 LangChain Chain / LLMChain / SequentialChain）
import "promptx"
import "llmx"
import "list"

// 单条 LLM 链：用 data 填充 prompt 模板 → 调用模型 → 返回回答
fn chainx_llm(cfg: map, template: str, data: map) -> str requires model
  let prompt = promptx_fill(template, data)
  let messages = []
  if cfg["system"] != ""
    messages = list_push(messages, {"role": "system", "content": cfg["system"]})
  messages = list_push(messages, {"role": "user", "content": prompt})
  return llmx_invoke(cfg, messages)

// 顺序链：chains 为 [{prompt, input_var}]，上一链输出作为下一链 input_var
fn chainx_sequential(cfg: map, chains: list, input: str) -> str requires model
  let mut res = input
  let mut i = 0
  while i < len(chains)
    let c = chains[i]
    let data = {"input": res}
    res = chainx_llm(cfg, c["prompt"], data)
    i = i + 1
  return res
