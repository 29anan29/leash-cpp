// memory — 对话记忆（对标 LangChain Memory）
// 消息格式: {"role": "system"|"user"|"assistant"|"tool", "content": str}
import "promptx"
import "list"

fn memory_new() -> list
  return []

fn memory_add(mem: list, role: str, content: str) -> list
  return list_push(mem, {"role": role, "content": content})

fn memory_get(mem: list) -> str
  return promptx_render(mem)

fn memory_last(mem: list)
  if len(mem) == 0
    return nil
  return mem[len(mem) - 1]

// 取最近 k 条（滑动窗口记忆）
fn memory_window(mem: list, k: int) -> list
  if len(mem) <= k
    return mem
  return list_slice(mem, len(mem) - k, len(mem))
