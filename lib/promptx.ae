// 提示词（prompt）构造辅助
import "string"

fn promptx_system(text: str)
    return "<<SYSTEM>>\n" + text

fn promptx_user(text: str)
    return "<<USER>>\n" + text

fn promptx_chat(messages: list)
    return str_join(messages, "\n")

fn promptx_fill(template: str, data: map)
    let keys = json_keys(data)
    let mut t = template
    let mut i = 0
    while i < len(keys)
        let k = keys[i]
        t = str_replace(t, "\{" + k + "\}", data[k])
        i = i + 1
    return t
