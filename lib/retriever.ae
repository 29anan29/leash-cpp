// retriever — 检索器（对标 LangChain Retriever，构建于向量库之上）
import "vector"
import "list"

fn retriever_build(docs: list) -> map
  let store = vector_new()
  let mut i = 0
  while i < len(docs)
    store = vector_add(store, docs[i])
    i = i + 1
  return store

fn retriever_search(store: map, query: str, k: int) -> list
  return vector_search(store, query, k)
