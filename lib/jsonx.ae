// JSON 扩展包（基于 json 原生包）
// 导入后可直接调用：jsonx_getpath / jsonx_keys / jsonx_stringify
// 依赖 string.ae（import "string"）与 json 原生包（package json）

import "string"
package json

fn jsonx_getpath(data, path: str)
    let parts = str_split(path, ".")
    let cur = data
    let mut i = 0
    while i < len(parts)
        cur = json_get(cur, parts[i])
        i = i + 1
    return cur

fn jsonx_keys(data) -> list
    return json_keys(data)

fn jsonx_stringify(data) -> str
    return stringify(data)
