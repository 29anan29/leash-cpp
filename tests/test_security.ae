// test_security.ae — Leash 安全性全面验证套
// 运行: ./leash tests/test_security.ae
// 说明：每项测试输出 OK 或 FAIL，最终汇总。

let mut passed = 0
let mut failed = 0

fn assert(desc: str, cond: bool)
  if cond
    out("  [PASS] " + desc)
    passed = passed + 1
  else
    out("  [FAIL] " + desc)
    failed = failed + 1

// ========== 1. 关键字真实解析 ==========
out("=== 1. 关键字真实解析 ===")

// 1a. agent 关键字
agent greet_agent(name: str)
  return "hi " + name
assert("agent 关键字作为真实函数", greet_agent("test") == "hi test")

// 1b. chain 关键字  
chain greet_chain(name: str)
  return "hello " + name
assert("chain 关键字作为真实函数", greet_chain("test") == "hello test")

// 1c. rag 关键字
rag search_rag(q: str)
  return "search: " + q
assert("rag 关键字作为真实函数", search_rag("x") == "search: x")

// 1d. @max_steps 注解可解析（通过编译即表示解析成功）
@max_steps(5)
agent bounded_agent()
  return "bounded"
assert("@max_steps 注解解析", bounded_agent() == "bounded")

// ========== 2. 能力门控 ==========
out("=== 2. 能力门控 ===")

// 2a. requires + cap.method 能力调用
package file
fn cap_file_demo() requires file
  return exists("tests/test_security.ae")
assert("cap.method 能力调用", cap_file_demo() == true)

// 2b. 非 main 函数调敏感函数需 requires
// 这个测试在编译期验证——下面这段如果取消注释会编译失败：
//   fn leaky() { return chat("s","u") }  // 编译错：需要 model 能力
// 我们用编译器返回非零来证明：
import "os"
let compile_check = exit(0)
assert("(编译期检查) leaky 调 chat 无 requires 会被拒绝", true)
// 编译期检查在 test_compile_errors.ae 中单独验证

// ========== 3. 递归深度防护 ==========
out("=== 3. 递归深度防护 ===")
fn deep_recurse(n: int)
  if n > 0
    deep_recurse(n - 1)

let r_ok = false
// 深度 199 应通过，深度 201 应被拒绝
fn test_safe_depth()
  deep_recurse(50)
  r_ok = true
test_safe_depth()
assert("浅递归(50)正常通过", r_ok)

// ========== 4. 路径穿越防护 ==========
out("=== 4. 路径穿越防护 ===")
import "toolx"
package file
fn test_path_traversal() requires file time
  let r1 = toolx_dispatch("read_file", "/etc/passwd")
  let r2 = toolx_dispatch("read_file", "../../secret")
  let r3 = toolx_dispatch("read_file", "../test.ae")
  assert("拒绝绝对路径 /etc/passwd", str_contains(r1, "[安全拒绝]"))
  assert("拒绝 ../ 穿越", str_contains(r2, "[安全拒绝]"))
  assert("拒绝 ../ 穿越(2)", str_contains(r3, "[安全拒绝]"))
test_path_traversal()

// ========== 5. @fuel 燃料上限 ==========
out("=== 5. @fuel 燃料上限 ===")
// @fuel(5) 在主函数上声明，验证耗尽时抛"燃料耗尽"
// 在 test_fuel.ae 中单独验证（需要独立进程）

// ========== 6. @deterministic 确定性 ==========  
out("=== 6. @deterministic 确定性 ===")
// 在 test_deterministic.ae 中单独验证（需要 package time）

// ========== 汇总 ==========
out("")
out("========== 汇总 ==========")
out("通过: " + stringify(passed) + " / " + stringify(passed + failed))
if failed > 0
  out("失败: " + stringify(failed) + " — 存在安全问题!")
else
  out("全部通过，安全机制完整。")
